<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { pageTitle, gtmContainerId }) %>

<body class="min-h-screen bg-background">

  <% if (gtmContainerId) { %>
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe
      src="https://www.googletagmanager.com/ns.html?id=<%= gtmContainerId %>"
      height="0"
      width="0"
      style="display:none;visibility:hidden">
    </iframe>
  </noscript>
  <% } %>

  <main class="min-h-screen grid grid-cols-1 lg:grid-cols-2">

    <!-- Form Panel -->
    <div class="flex flex-col">

      <!-- Logo -->
      <div class="flex gap-2 items-center p-4 lg:p-8">
        <img
          src="data:image/svg+xml;base64,"
          width="30"
          height="24"
          alt="OWOX Data Marts"
        />
        <div class="text-base font-bold text-foreground tracking-tight">
          OWOX Data Marts
        </div>
      </div>

      <!-- Content -->
      <div class="flex-1 flex w-full h-full items-center justify-center p-4 lg:p-8">
          <%- body %>
      </div>

      <!-- Footer -->
      <%- include('../partials/footer') %>

    </div>

    <!-- Brand Panel (Desktop only) -->
    <aside class="hidden lg:flex w-full">
      <%- include('../partials/brand-panel') %>
    </aside>

  </main>

</body>
</html>