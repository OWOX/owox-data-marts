                <path d="M22.1161 12.2282C22.1161 10.8118 21.6632 9.42842 20.8068 8.30029L18.4846 10.6224C19.2093 11.9564 18.954 13.6033 17.8506 14.6491L19.1187 17.737C20.9797 16.5266 22.1161 14.4515 22.1161 12.2282Z" fill="#FBBC04" />
                <path d="M15.6108 15.5637H15.5531C14.1286 15.5637 12.8604 14.6579 12.3993 13.3075C11.9382 11.957 12.3828 10.4666 13.511 9.58547C14.6391 8.70438 16.1954 8.64674 17.3894 9.43725L19.6951 7.13159C17.4553 5.31176 14.2932 5.17177 11.897 6.78574C9.50076 8.3997 8.44675 11.3806 9.28667 14.1392C10.1266 16.8977 12.671 18.7834 15.5531 18.7834C15.9978 18.7834 16.4425 18.7422 16.8789 18.6517L15.6108 15.5637Z" fill="#EA4335" />
                <path d="M23.87 18.231C22.4125 18.231 20.9632 18.4451 19.5716 18.8568L21.4161 23.3611C22.2148 23.1634 23.0383 23.0646 23.87 23.0646C28.6625 23.0646 32.7797 26.449 33.7184 31.1509C34.6489 35.8528 32.1374 40.5547 27.7155 42.3828C23.2936 44.2108 18.1882 42.6627 15.5284 38.6855C12.8687 34.7082 13.3792 29.3969 16.7636 26.0043C17.4718 25.2962 18.2787 24.7033 19.1598 24.2339L17.34 19.7461C10.5465 23.0728 7.32686 30.9697 9.86308 38.1008C12.3993 45.2319 19.8762 49.3244 27.2461 47.6117C34.616 45.9071 39.532 38.9407 38.6756 31.4226C37.8192 23.9045 31.454 18.231 23.8864 18.231H23.87Z" fill="#4285F4" />
              </svg>
              <span class="text-[10px] font-semibold text-foreground leading-none">Looker Studio</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Error message -->
  <p id="onboarding-error" class="text-sm text-red-600 min-h-[20px] mt-4" aria-live="polite"></p>

  <!-- Navigation -->
  <div class="flex items-center justify-between mt-6">
    <button
      id="btn-back"
      type="button"
      class="hidden text-sm font-medium text-muted-foreground hover:text-foreground transition-colors px-3 py-2"
    >
      &larr; Back
    </button>
    <div class="flex items-center gap-3 ml-auto">
      <button
        id="btn-next"
        type="button"
        class="inline-flex justify-center items-center gap-2 py-2 px-5 rounded-md text-sm font-medium text-primary-foreground bg-primary hover:bg-primary/90 transition-colors disabled:opacity-60"
      >
        Next &rarr;
      </button>
    </div>
  </div>
</div>

<div
  id="owox-cloud-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50"
  role="dialog"
  aria-modal="true"
  aria-labelledby="owox-cloud-modal-title"
  aria-hidden="true"
>
  <div class="bg-background border border-border rounded-lg shadow-lg max-w-md w-full p-6">
    <div class="flex gap-3">
      <svg class="shrink-0 w-8 h-8 mt-0.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="#199EE3" stroke-width="1.75" />
        <path d="M12 8v5M12 16h.01" stroke="#199EE3" stroke-width="1.75" stroke-linecap="round" />
      </svg>
      <div class="min-w-0">
        <h3 id="owox-cloud-modal-title" class="text-base font-semibold text-foreground">OWOX Cloud is coming soon</h3>
        <p class="text-sm text-muted-foreground mt-3">We're still building our managed storage.</p>
        <p class="text-sm text-muted-foreground mt-2">We'll reach out as soon as it's available. In the meantime, feel free to select one of the supported warehouses to get started.</p>
      </div>
    </div>
    <button
      type="button"
      id="owox-cloud-modal-ok"
      class="mt-6 w-full inline-flex justify-center items-center py-2.5 px-4 rounded-md text-sm font-medium text-primary-foreground bg-primary hover:bg-primary/90 transition-colors"
    >
      Got it
    </button>
  </div>
</div>

<script>
(function () {
  const TOTAL_STEPS = 4;
  let currentStep = 0;

  // Domain validation pattern
  const ORG_DOMAIN_PATTERN = /^[a-zA-Z0-9][a-zA-Z0-9.-]*\.[a-zA-Z]{2,}$/;

  function stripLeadingWww(host) {
    return host.replace(/^www\./i, '');
  }

  /** Hostname from pasted URL or plain domain (https://owox.com/demo → owox.com, strips www.). */
  function normalizeOrgDomainInput(raw) {
    const trimmed = raw.trim();
    if (!trimmed) return '';
    let candidate = trimmed;
    if (!/^[a-z][a-z0-9+.-]*:\/\//i.test(candidate)) {
      candidate = 'https://' + candidate;
    }
    try {
      const u = new URL(candidate);
      if (u.hostname) return stripLeadingWww(u.hostname.toLowerCase());
    } catch {
      // ignore
    }
    return stripLeadingWww(
      trimmed
        .replace(/^https?:\/\//i, '')
        .split('/')[0]
        .split('?')[0]
        .split('#')[0]
        .toLowerCase()
    );
  }

  const slides = document.querySelectorAll('.question-slide');
  const dots = document.querySelectorAll('.progress-dot');
  const counter = document.getElementById('step-counter');
  const btnBack = document.getElementById('btn-back');
  const btnNext = document.getElementById('btn-next');
  const errorEl = document.getElementById('onboarding-error');
  const owoxCloudModal = document.getElementById('owox-cloud-modal');
  const owoxCloudModalOk = document.getElementById('owox-cloud-modal-ok');

  const OWOX_CLOUD_STORAGE_VALUES = new Set(['owox_cloud_eu', 'owox_cloud_us']);
  let owoxModalPreviousFocus = null;

  function isOwoxCloudModalOpen() {
    return owoxCloudModal && !owoxCloudModal.classList.contains('hidden');
  }

  function openOwoxCloudModal() {
    if (!owoxCloudModal || !owoxCloudModalOk) return;
    owoxModalPreviousFocus = document.activeElement;
    owoxCloudModal.classList.remove('hidden');
    owoxCloudModal.classList.add('flex');
    owoxCloudModal.setAttribute('aria-hidden', 'false');
    owoxCloudModalOk.focus();
  }

  function closeOwoxCloudModal() {
    if (!owoxCloudModal) return;
    owoxCloudModal.classList.add('hidden');
    owoxCloudModal.classList.remove('flex');
    owoxCloudModal.setAttribute('aria-hidden', 'true');
    const prev = owoxModalPreviousFocus;
    owoxModalPreviousFocus = null;
    if (prev && typeof prev.focus === 'function') {
      prev.focus();
    }
  }

  // Validate redirect is a safe relative path
  const urlParams = new URLSearchParams(window.location.search);
  const rawRedirect = urlParams.get('redirect') || '/';
  const redirectUrl = (rawRedirect.startsWith('/') && !rawRedirect.startsWith('//')) ? rawRedirect : '/';

  function showStep(step) {
    const container = document.getElementById('onboarding-container');
    if (container) {
      if (step === 3) {
        container.classList.remove('max-w-lg');
        container.classList.add('max-w-4xl');
      } else {
        container.classList.remove('max-w-4xl');
        container.classList.add('max-w-lg');
      }
    }

    slides.forEach((slide, i) => {
      slide.classList.remove('slide-hidden', 'slide-hidden-left');
      if (i < step) slide.classList.add('slide-hidden-left');
      else if (i > step) slide.classList.add('slide-hidden');
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-primary', i <= step);
      dot.classList.toggle('w-8', i === step);
      dot.classList.toggle('bg-border', i > step);
      dot.classList.toggle('w-6', i !== step);
    });
    counter.textContent = (step + 1) + ' / ' + TOTAL_STEPS;
    btnBack.classList.toggle('hidden', step === 0);

    if (step === TOTAL_STEPS - 1) {
      btnNext.textContent = 'Finish';
    } else {
      btnNext.innerHTML = 'Next &rarr;';
    }
    errorEl.textContent = '';
    currentStep = step;
  }

  // Validate current step — returns true if valid
  function validateStep(step) {
    if (step === 0) {
      // Use case: at least one checkbox must be selected
      const checked = document.querySelectorAll('#q-use-case input[type="checkbox"]:checked');
      if (checked.length === 0) {
        errorEl.textContent = 'Please select at least one option.';
        return false;
      }
      const otherCb = document.getElementById('use-case-other-cb');
      if (otherCb && otherCb.checked) {
        const otherText = document.getElementById('use-case-other-text');
        if (!otherText || !otherText.value.trim()) {
          errorEl.textContent = 'Please specify your use case in the "Other" field.';
          return false;
        }
      }
      return true;
    }
    if (step === 1) {
      const input = document.getElementById('org-domain');
      const raw = input.value.trim();
      if (!raw) {
        errorEl.textContent = 'Please enter your organization domain.';
        return false;
      }
      const val = normalizeOrgDomainInput(raw);
      if (val !== input.value) {
        input.value = val;
      }
      if (!ORG_DOMAIN_PATTERN.test(val)) {
        errorEl.textContent = 'Please enter a valid domain (e.g., example.com or sub.example.com).';
        return false;
      }
      return true;
    }
    if (step === 2) {
      // Primary role: one radio must be selected
      const checked = document.querySelector('#q-primary-role input[type="radio"]:checked');
      if (!checked) {
        errorEl.textContent = 'Please select your primary role.';
        return false;
      }
      if (checked.value === 'other') {
        const otherText = document.getElementById('role-other-text');
        if (!otherText || !otherText.value.trim()) {
          errorEl.textContent = 'Please specify your role in the "Other" field.';
          return false;
        }
      }
      return true;
    }
    if (step === 3) {
      // Primary storage: one radio must be selected
      const checked = document.querySelector('#q-primary-storage input[type="radio"]:checked');
      if (!checked) {
        errorEl.textContent = 'Please select your primary storage.';
        return false;
      }
      if (checked.value === 'other') {
        const otherText = document.getElementById('storage-other-text');
        if (!otherText || !otherText.value.trim()) {
          errorEl.textContent = 'Please specify your storage in the "Other" field.';
          return false;
        }
      }
      return true;
    }
    return true;
  }

  // Option card highlight on selection
  function setupOptionCards() {
    document.querySelectorAll('.option-card input[type="checkbox"]').forEach(cb => {
      cb.addEventListener('change', () => {
        cb.closest('.option-card').classList.toggle('selected', cb.checked);
      });
    });
    document.querySelectorAll('.option-card input[type="radio"]').forEach(rb => {
      rb.addEventListener('change', () => {
        const group = rb.closest('.space-y-2');
        group.querySelectorAll('.option-card').forEach(card => card.classList.remove('selected'));
        rb.closest('.option-card').classList.add('selected');
      });
    });
  }

  // "Other" text field toggle
  function setupOtherToggles() {
    const toggles = [
      { trigger: 'use-case-other-cb', wrap: 'use-case-other-wrap', type: 'checkbox' },
      { trigger: 'role-other-rb', wrap: 'role-other-wrap', type: 'radio' },
      { trigger: 'storage-other-rb', wrap: 'storage-other-wrap', type: 'radio' },
    ];
    toggles.forEach(({ trigger, wrap, type }) => {
      const el = document.getElementById(trigger);
      const wrapEl = document.getElementById(wrap);
      if (!el || !wrapEl) return;
      if (type === 'checkbox') {
        el.addEventListener('change', () => {
          wrapEl.classList.toggle('visible', el.checked);
        });
      } else {
        const name = el.getAttribute('name');
        document.querySelectorAll('input[name="' + name + '"]').forEach(rb => {
          rb.addEventListener('change', () => {
            wrapEl.classList.toggle('visible', el.checked);
          });
        });
      }
    });
  }

  function collectAnswers() {
    const answers = [];

    // Q1: Use case (multi-select)
    const useCaseChecked = Array.from(
      document.querySelectorAll('#q-use-case input[type="checkbox"]:checked')
    ).map(cb => cb.value);
    if (useCaseChecked.length > 0) {
      const item = { questionId: 'use_case', answerValue: useCaseChecked };
      const otherText = document.getElementById('use-case-other-text');
      if (useCaseChecked.includes('other') && otherText?.value?.trim()) {
        item.otherText = otherText.value.trim();
      }
      answers.push(item);
    }

    // Q2: Org domain (hostname; URLs normalized with URL API)
    const domainInput = document.getElementById('org-domain');
    if (domainInput?.value?.trim()) {
      const host = normalizeOrgDomainInput(domainInput.value);
      if (host) {
        answers.push({ questionId: 'org_domain', answerValue: host });
      }
    }

    // Q3: Primary role (single-select)
    const roleChecked = document.querySelector('#q-primary-role input[type="radio"]:checked');
    if (roleChecked) {
      const item = { questionId: 'primary_role', answerValue: roleChecked.value };
      const otherText = document.getElementById('role-other-text');
      if (roleChecked.value === 'other' && otherText?.value?.trim()) {
        item.otherText = otherText.value.trim();
      }
      answers.push(item);
    }

    // Q4: Primary storage (single-select)
    const storageChecked = document.querySelector('#q-primary-storage input[type="radio"]:checked');
    if (storageChecked) {
      const item = { questionId: 'primary_storage', answerValue: storageChecked.value };
      const otherText = document.getElementById('storage-other-text');
      if (storageChecked.value === 'other' && otherText?.value?.trim()) {
        item.otherText = otherText.value.trim();
      }
      answers.push(item);
    }

    return answers;
  }

  async function submitAnswers() {
    const answers = collectAnswers();
    if (answers.length < TOTAL_STEPS) {
      errorEl.textContent = 'Please answer all questions before submitting.';
      return;
    }

    btnNext.disabled = true;
    errorEl.textContent = '';

    try {
      const resp = await fetch('/auth/onboarding', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers, redirect: redirectUrl }),
      });
      if (resp.ok) {
        const data = await resp.json().catch(() => null);
        window.location.href = (data && data.redirect) || redirectUrl;
      } else {
        const data = await resp.json().catch(() => null);
        errorEl.textContent = (data && data.error) || 'Failed to save answers. Please try again.';
      }
    } catch (err) {
      errorEl.textContent = 'Network error. Please try again.';
    } finally {
      btnNext.disabled = false;
    }
  }

  if (owoxCloudModalOk) {
    owoxCloudModalOk.addEventListener('click', () => {
      closeOwoxCloudModal();
      submitAnswers();
    });
  }

  btnNext.addEventListener('click', () => {
    if (!validateStep(currentStep)) return;
    if (currentStep < TOTAL_STEPS - 1) {
      showStep(currentStep + 1);
    } else {
      const storageChecked = document.querySelector('#q-primary-storage input[type="radio"]:checked');
      if (
        storageChecked &&
        OWOX_CLOUD_STORAGE_VALUES.has(storageChecked.value) &&
        owoxCloudModal &&
        owoxCloudModalOk
      ) {
        openOwoxCloudModal();
      } else {
        submitAnswers();
      }
    }
  });

  btnBack.addEventListener('click', () => {
    if (currentStep > 0) showStep(currentStep - 1);
  });

  // Keyboard navigation — skip when focus is in a text input (let it behave normally)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOwoxCloudModalOpen()) {
      e.preventDefault();
      closeOwoxCloudModal();
      return;
    }
    if (e.key === 'Enter' && !e.shiftKey) {
      if (isOwoxCloudModalOpen()) return;
      if (e.target && e.target.tagName === 'INPUT' && e.target.type === 'text') return;
      e.preventDefault();
      btnNext.click();
    }
  });

  // Shuffle option cards within a container, keeping "Other" (value="other") last.
  function shuffleOptions(containerId) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const cards = Array.from(container.querySelectorAll(':scope > label.option-card'));
    if (cards.length < 2) return;

    // Separate "other" card from the rest
    const otherCard = cards.find(function (label) {
      var input = label.querySelector('input');
      return input && input.value === 'other';
    });
    var shuffleable = cards.filter(function (c) { return c !== otherCard; });

    // Fisher-Yates shuffle
    for (var i = shuffleable.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = shuffleable[i];
      shuffleable[i] = shuffleable[j];
      shuffleable[j] = tmp;
    }

    // Remove only option-card labels from DOM (keep other-text-input divs)
    cards.forEach(function (c) { container.removeChild(c); });

    // Re-insert: shuffled cards first, then "other" card (before the other-text-input div if present)
    var otherWrap = container.querySelector('.other-text-input');
    shuffleable.forEach(function (c) {
      if (otherWrap) container.insertBefore(c, otherWrap);
      else container.appendChild(c);
    });
    if (otherCard) {
      if (otherWrap) container.insertBefore(otherCard, otherWrap);
      else container.appendChild(otherCard);
    }
  }

  // Shuffle primary storage: randomize DWH options only; fix OWOX (EU→US), "Don't have it yet", then Other data warehouse.
  function shufflePrimaryStorageOptions() {
    const container = document.getElementById('q-primary-storage');
    if (!container) return;
    const cards = Array.from(container.querySelectorAll(':scope > label.option-card'));
    if (cards.length < 2) return;

    const otherCard = cards.find(function (label) {
      var input = label.querySelector('input');
      return input && input.value === 'other';
    });
    const dontKnowCard = cards.find(function (label) {
      var input = label.querySelector('input');
      return input && input.value === 'dont_know';
    });
    const owoxEuCard = cards.find(function (label) {
      var input = label.querySelector('input');
      return input && input.value === 'owox_cloud_eu';
    });
    const owoxUsCard = cards.find(function (label) {
      var input = label.querySelector('input');
      return input && input.value === 'owox_cloud_us';
    });
    var pinned = new Set(
      [otherCard, dontKnowCard, owoxEuCard, owoxUsCard].filter(Boolean)
    );
    var shuffleable = cards.filter(function (c) { return !pinned.has(c); });

    for (var i = shuffleable.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = shuffleable[i];
      shuffleable[i] = shuffleable[j];
      shuffleable[j] = tmp;
    }

    cards.forEach(function (c) { container.removeChild(c); });

    var otherWrap = container.querySelector('.other-text-input');
    function insertBeforeOther(node) {
      if (node) {
        if (otherWrap) container.insertBefore(node, otherWrap);
        else container.appendChild(node);
      }
    }
    shuffleable.forEach(function (c) {
      insertBeforeOther(c);
    });
    insertBeforeOther(owoxEuCard);
    insertBeforeOther(owoxUsCard);
    insertBeforeOther(dontKnowCard);
    insertBeforeOther(otherCard);
  }

  shuffleOptions('q-use-case');
  shuffleOptions('q-primary-role');
  shufflePrimaryStorageOptions();

  setupOptionCards();
  setupOtherToggles();

  const orgDomainEl = document.getElementById('org-domain');
  if (orgDomainEl) {
    orgDomainEl.addEventListener('blur', () => {
      const raw = orgDomainEl.value.trim();
      if (!raw) return;
      const host = normalizeOrgDomainInput(raw);
      if (host && ORG_DOMAIN_PATTERN.test(host)) {
        orgDomainEl.value = host;
      }
    });
  }

  showStep(0);
})();
</script>
