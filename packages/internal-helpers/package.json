{
  "name": "@owox/internal-helpers",
  "version": "0.30.1",
  "description": "Internal helpers used by core OWOX packages",
  "type": "module",
  "author": "OWOX",
  "license": "ELv2",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "homepage": "https://github.com/OWOX/owox-data-marts",
  "bugs": "https://github.com/OWOX/owox-data-marts/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWOX/owox-data-marts.git"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:cjs:pkg",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:cjs:pkg": "shx cp cjs-package.json dist-cjs/package.json",
    "build:clean": "shx rm -rf dist dist-cjs tsconfig.tsbuildinfo",
    "build:esm": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"**/*.{ts,js,json}\" --ignore-path ../../.prettierignore",
    "format:check": "prettier --check \"**/*.{ts,js,json}\" --ignore-path ../../.prettierignore",
    "inject-posthog-key": "node scripts/inject-posthog-key.mjs",
    "lint": "eslint . --config ./eslint.config.js",
    "lint:fix": "eslint . --fix --config ./eslint.config.js",
    "lint:md": "markdownlint-cli2 --config ../../.markdownlint-cli2.mjs",
    "lint:md:fix": "markdownlint-cli2 --config ../../.markdownlint-cli2.mjs --fix",
    "prebuild": "npm run build:clean",
    "prepublishOnly": "npm run lint && npm run typecheck",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "keywords": [
    "owox-internal-helpers",
    "owox-package",
    "owox"
  ],
  "dependencies": {
    "@google-cloud/pino-logging-gcp-config": "^1.2.0",
    "@sendgrid/mail": "^8.1.6",
    "dotenv": "^16.4.7",
    "env-paths": "^3.0.0",
    "google-auth-library": "^9.14.3",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.11.0",
    "pino-pretty": "^13.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/storage": "^7.21.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@owox/eslint-config": "*",
    "@owox/prettier-config": "*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "peerDependencies": {
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/storage": "^7.21.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/opentelemetry-cloud-trace-exporter": {
      "optional": true
    },
    "@google-cloud/storage": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-node": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "dist-cjs"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
