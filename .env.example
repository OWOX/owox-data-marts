# --- owox variables ------------------------------------------------------------------------
# Logging format. Options: pretty (Human-readable format), pretty-verbose (Human-readable format extended additional data)  json (production-ready JSON format), gcp-cloud-logging
# Default: pretty
LOG_FORMAT=json

# Log level threshold. Only logs at this level or higher will be output
# Options: trace, debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Port number for the application server
# Default: 3000
PORT=

# Base URL of the application [scheme + host (+ optional port)]
# Examples: http://localhost:3000, https://data-marts.example.com
# Default: http://localhost:${PORT}
PUBLIC_ORIGIN=

# Comma-separated HTTPS origins allowed as OAuth redirect targets for dynamic MCP clients.
# Loopback HTTP redirects for desktop/CLI clients are always allowed.
# Example for Claude web: https://claude.ai
# Default: empty
MCP_DYNAMIC_CLIENT_ALLOWED_REDIRECT_ORIGINS=

# OpenAI Apps domain-verification token. Served verbatim as text/plain at
# https://<mcp-host>/.well-known/openai-apps-challenge (public, no auth). Supplied by
# OpenAI in the app submission UI; leave empty to disable the endpoint (returns 404).
# Default: empty
MCP_OPENAI_APPS_CHALLENGE_TOKEN=
# -------------------------------------------------------------------------------------------

# --- @owox/backend variables ---------------------------------------------------------------

# Database type for backend. Options: sqlite, mysql
# Default: sqlite
DB_TYPE=

## -- SQLite database variables ---- 
# Absolute or relative path to database file. Automatically creates the database directory if it doesn't exist
# Examples: ./path/to/database/backend.db, C:\path\to\database\backend.db
# Default: uses cross-platform application data directory with 'owox/sqlite/app.db' structure
SQLITE_DB_PATH=

# OR (if choosing DB_TYPE=mysql) 

## -- MySQL database variables ----
# MySQL database host
# Examples: localhost, 127.0.0.1, mysql.example.com
DB_HOST=
# MySQL database port
DB_PORT=database-port
# MySQL database username
DB_USERNAME=database-user-name
# MySQL database password
DB_PASSWORD=database-user-password
# MySQL database name
DB_DATABASE=database-name
# -------------------------------------------------------------------------------------------

# --- @owox/idp-protocol variables ----------------------------------------------------------
# Type of Identity Provider protocol used for authentication and authorization implementation
# Options: none, better-auth
# Default: none
IDP_PROVIDER=
# -------------------------------------------------------------------------------------------

# --- Google Tag Manager configuration ------------------------------------------------------
# Google Tag Manager Container ID
# When set, enables Google Tag Manager on all web pages
# Example: GTM-XXXXXXX
GOOGLE_TAG_MANAGER_CONTAINER_ID=
# -------------------------------------------------------------------------------------------

# --- @owox/idp-better-auth  (if choose IDP_PROVIDER=better-auth) ---------------------------
# Secret key for signing (min. 32 characters). Required
IDP_BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-long
# -------------------------------------------------------------------------------------------

# --- Google Sheets Extension Authentication -------------------------------------------------
# Google OAuth Client ID for Apps Script (the audience for ID tokens)
# Example: 123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_SHEETS_EXTENSION_CLIENT_ID=

# Origin URL for Google Sheets Extension requests (for CORS configuration)
# Set this to your Google Apps Script origin if using self-hosted deployment
# If unset, the Google Sheets Extension might be unable to connect to the server due to CORS restrictions.
GOOGLE_SHEETS_EXTENSION_ORIGIN=
# -------------------------------------------------------------------------------------------

# --- Anonymous CLI usage telemetry (PostHog) ---
# Telemetry is ON by default and fully anonymous. Disable it with either of:
# OWOX_TELEMETRY_DISABLED=1
# DO_NOT_TRACK=1
# Optional overrides (defaults target the OWOX PostHog project):
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://eu.i.posthog.com

# Semantic search is always enabled (core feature). The settings below tune it.

# HTTP search query limits and default response size.
# SEARCH_QUERY_MIN_LENGTH=2
# SEARCH_QUERY_MAX_LENGTH=256
# SEARCH_TOP_K=25

# Local directory for caching the downloaded ONNX model files
# Default: uses @huggingface/transformers default cache; in production set to a vendored path inside the image
# ADVANCED_SEARCH_MODEL_CACHE_DIR=

# Embedding provider: local (fixed ONNX model, default) or openrouter
# ADVANCED_SEARCH_EMBEDDING_PROVIDER=local

# OpenRouter embedding model and output dimensions.
# These settings are used only when ADVANCED_SEARCH_EMBEDDING_PROVIDER=openrouter.
# ADVANCED_SEARCH_OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-2
# ADVANCED_SEARCH_OPENROUTER_EMBEDDING_DIMENSIONS=768
# ADVANCED_SEARCH_OPENROUTER_API_KEY=
# ADVANCED_SEARCH_OPENROUTER_ALLOWED_PROVIDERS=google-vertex
# ADVANCED_SEARCH_OPENROUTER_DATA_COLLECTION=deny
# ADVANCED_SEARCH_OPENROUTER_ZDR=true
# ADVANCED_SEARCH_OPENROUTER_REQUEST_TIMEOUT_MS=60000

# OpenRouter embeddings batching is disabled by default because some BYOK routes only support one input per request
# Default: false
# ADVANCED_SEARCH_OPENROUTER_BATCHING_ENABLED=false

# Maximum OpenRouter inputs per request when OpenRouter batching is enabled
# Default: 20
# ADVANCED_SEARCH_OPENROUTER_BATCH_SIZE=20

# Cron schedule for the drift-scan that enqueues per-(type, project) reindex tasks for stale entities
# Default: hourly
# ADVANCED_SEARCH_DRIFT_CRON=0 * * * *

# Cron schedules for processing targeted entity and project reindex trigger queues
# Defaults keep current staggered processing cadence
# ADVANCED_SEARCH_ENTITY_PROCESSING_CRON=*/2 * * * * *
# ADVANCED_SEARCH_DATA_MART_PROJECT_PROCESSING_CRON=0,30 * * * * *
# ADVANCED_SEARCH_DATA_STORAGE_PROJECT_PROCESSING_CRON=10,40 * * * * *
# ADVANCED_SEARCH_DATA_DESTINATION_PROJECT_PROCESSING_CRON=20,50 * * * * *

# Vector candidate over-fetch multiplier: the DB vector branch fetches multiplier * topK
# candidates, then application-side ranking trims to topK. Default: 2
# ADVANCED_SEARCH_VECTOR_CANDIDATE_MULTIPLIER=2

# Maximum number of search results returned per query
# Default: 10
# ADVANCED_SEARCH_TOP_K=10

# Number of entities processed per embedding batch during project reindex
# Default: 50
# ADVANCED_SEARCH_INDEX_BATCH_SIZE=50

# Maximum number of DB candidates loaded per entity type before in-memory reranking
# Default: 500
# ADVANCED_SEARCH_CANDIDATE_LIMIT=500

# Maximum accepted search query length in characters
# Default: 256
# ADVANCED_SEARCH_QUERY_MAX_LENGTH=256

# Maximum number of local ONNX embedding inference calls running at once
# Default: 2
# ADVANCED_SEARCH_EMBEDDING_CONCURRENCY=2

# Minimum relevance (vector+keyword similarity, excluding the extendability bonus) a result must
# reach to be returned. Raise to surface only strongly matching entities; set 0 to disable the filter.
# Default: 45
# ADVANCED_SEARCH_MIN_RELEVANCE=45
# -----------------------------------------------------------------------------------------------

# --- MCP instrumentation / logging (#6710) --------------------------------------------------
# t1 (stdout→BQ) is always on via the `logger` transport on the shared event bus.
# Comma-separated list of shared-bus transports. Options: logger, posthog. OTLP is NOT enabled here.
# Default: logger
INTEGRATIONS_TRANSPORTS=logger

# Tool arguments/results/SQL can carry client data (PII), so by DEFAULT they are kept OUT of the
# general logs:
#   - no bucket, no opt-in           ⇒ dropped (only tool name/status/duration/error are logged)
#   - MCP_LOG_GCS_BUCKET set          ⇒ offloaded to GCS (ADC-gated), never inlined into logs
#   - MCP_LOG_INLINE_PAYLOADS=true    ⇒ small ones inlined into the logs (opt-in; accepts PII in logs)

# GCS bucket for MCP tool-call payloads. Set ⇒ arguments/results/SQL are written to GCS (the object
# is referenced by owox_payload_ref) instead of the logs.
# Default: empty
MCP_LOG_GCS_BUCKET=

# Opt in to inlining small tool arguments/results/SQL into the logs (and OTLP span attributes).
# Off by default because those payloads can contain client data (PII).
# Default: false
MCP_LOG_INLINE_PAYLOADS=false

# Max size (bytes) of an inlined payload — applies when MCP_LOG_INLINE_PAYLOADS=true (and as the GCS
# offload threshold). Covers the combined blob (arguments + result + SQL).
# Default: 4096
MCP_LOG_INLINE_MAX_BYTES=4096

# t2 (OTLP) — a SEPARATE, independent switch, off by default. NOT controlled via
# INTEGRATIONS_TRANSPORTS, so insights events (which may carry PII) never reach an external OTLP
# backend; when enabled, the OTLP transport only forwards mcp.* events on top of the logger transport.
# Tool arguments/results reach OTLP span attributes only when MCP_LOG_INLINE_PAYLOADS=true (small
# ones); otherwise spans carry identity/status only and payloads go to GCS or are dropped.
# Tool calls are grouped into a per-conversation trace (one root span, one child span per call).
# Default: false
MCP_OTEL_ENABLED=false

# t2 exporter: http/protobuf (default) | gcp.
# - http/protobuf: OTLP to OTEL_EXPORTER_OTLP_ENDPOINT.
# - gcp: GCP Cloud Trace via application-default credentials (same ADC as the GCS bucket) + auto
#   project — NO endpoint/headers. Needs the Cloud Trace API enabled + trace-append permission, and a
#   project (GOOGLE_CLOUD_PROJECT or ADC quota project). Stays in GCP, no external vendor.
# Default: http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# OTLP endpoint. Required for http/protobuf (ignored for gcp). Auth via OTEL_EXPORTER_OTLP_HEADERS
# (e.g. Authorization=Bearer <key>).
# - http/protobuf: full HTTP traces URL incl. path, e.g. https://collector.example.com/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# -------------------------------------------------------------------------------------------
